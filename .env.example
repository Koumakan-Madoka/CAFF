# Copy this file to .env.local for local development.
# `npm run start` and `npm run start:dev` auto-load .env.local if it exists.
# Existing process environment variables still win over values from the file.

CHAT_APP_HOST=127.0.0.1
CHAT_APP_PORT=3100

# Optional local overrides
# PI_CODING_AGENT_DIR=
# PI_SQLITE_PATH=

# Feishu integration
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Webhook mode only
FEISHU_VERIFICATION_TOKEN=
# Optional fallback when GET /open-apis/bot/v3/info is unavailable
# FEISHU_BOT_OPEN_ID=
# Inbound mode: webhook | long-connection
# FEISHU_CONNECTION_MODE=webhook
# Optional official SDK long connection log level: fatal | error | warn | info | debug | trace
# FEISHU_LONG_CONNECTION_LOGGER_LEVEL=info
