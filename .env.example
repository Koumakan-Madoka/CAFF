# Copy this file to .env.local for local development.
# `npm run start` and `npm run start:dev` auto-load .env.local if it exists.
# Existing process environment variables still win over values from the file.

CHAT_APP_HOST=127.0.0.1
CHAT_APP_PORT=3100

# OpenSandbox local lifecycle server / chat bridge POC
# Build the official JS SDK from a local OpenSandbox checkout, then point CAFF at it.
# CAFF_SKILL_TEST_OPENSANDBOX_API_URL=http://localhost:8080
# On Windows + WSL, `localhost` is usually safer than `127.0.0.1` for forwarded ports.
# CAFF_SKILL_TEST_OPENSANDBOX_SDK_PATH=../OpenSandbox/sdks/sandbox/javascript/dist/index.js
# CAFF_SKILL_TEST_OPENSANDBOX_IMAGE=node:20-bookworm
# Optional: use a pre-baked runtime image so CAFF stops re-uploading runner + pi package every case.
# 1) Build it once: npm run opensandbox:build-runtime-image
# 2) Then set:
# CAFF_SKILL_TEST_OPENSANDBOX_IMAGE=caff-skill-test-runtime:local
# CAFF_SKILL_TEST_OPENSANDBOX_PREBAKED_RUNTIME_DIR=/opt/caff-skill-test/runtime
# Optional: use a fuller CAFF source image so sandbox cases see a realistic repo checkout.
# 1) Build it once: npm run opensandbox:build-caff-image
# 2) Then set:
# CAFF_SKILL_TEST_OPENSANDBOX_IMAGE=caff-skill-test-caff:local
# CAFF_SKILL_TEST_OPENSANDBOX_PREBAKED_RUNTIME_DIR=/opt/caff-skill-test/runtime
# CAFF_SKILL_TEST_OPENSANDBOX_PREBAKED_PROJECT_DIR=/opt/caff-skill-test/project
# CAFF_SKILL_TEST_OPENSANDBOX_TIMEOUT_SEC=300
# Full-mode local runs can exceed 5 minutes while uploading the isolated world; raise this locally (for example 3600).
# CAFF_SKILL_TEST_OPENSANDBOX_USE_SERVER_PROXY=true
# Bind broadly, then advertise a sandbox-reachable URL.
# CHAT_APP_HOST=0.0.0.0
# CHAT_APP_ADVERTISE_URL=http://192.168.1.10:3100
# Optional sandbox-only override when the advertised URL differs.
# CAFF_SKILL_TEST_OPENSANDBOX_CHAT_API_URL=

# Optional local overrides
# PI_CODING_AGENT_DIR=
# PI_SQLITE_PATH=

# Feishu integration
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Webhook mode only
FEISHU_VERIFICATION_TOKEN=
# Optional fallback when GET /open-apis/bot/v3/info is unavailable
# FEISHU_BOT_OPEN_ID=
# Inbound mode: webhook | long-connection
# FEISHU_CONNECTION_MODE=webhook
# Optional official SDK long connection log level: fatal | error | warn | info | debug | trace
# FEISHU_LONG_CONNECTION_LOGGER_LEVEL=info
