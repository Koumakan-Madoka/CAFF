# Auto-detect text files and normalize line endings to LF on checkout
* text=auto

# Explicitly enforce LF for all text file types in this repo
*.md text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.ps1 text eol=lf
*.sh text eol=lf
*.css text eol=lf
*.html text eol=lf
*.txt text eol=lf
